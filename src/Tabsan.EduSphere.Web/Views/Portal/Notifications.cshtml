@model Tabsan.EduSphere.Web.Models.Portal.NotificationsPageModel
@{ ViewData["Title"] = "Notifications"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h5 mb-0">Inbox</h2>
            @if (Model.UnreadCount > 0)
            {
                <span class="badge bg-danger">@Model.UnreadCount unread</span>
            }
        </div>
        <form asp-action="MarkAllRead" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-secondary">Mark All Read</button>
        </form>
    </div>

    @if (Model.Notifications.Count == 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-muted py-5">
                <div class="fs-1 mb-2">🔔</div>
                <p class="mb-0">No notifications yet.</p>
            </div>
        </div>
    }
    else
    {
        <div class="list-group shadow-sm">
            @foreach (var n in Model.Notifications)
            {
                <div class="list-group-item list-group-item-action @(n.IsRead ? "" : "fw-semibold bg-light")">
                    <div class="d-flex justify-content-between">
                        <span>@n.Title</span>
                        <small class="text-muted">@n.CreatedAt.ToString("dd MMM yyyy, HH:mm")</small>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(n.Body))
                    {
                        <div class="small text-muted mt-1">@n.Body</div>
                    }
                    <div class="mt-1 d-flex align-items-center gap-2">
                        <span class="badge bg-secondary">@n.NotificationType</span>
                        @if (!n.IsRead)
                        {
                            <span class="badge bg-primary">New</span>
                            @* Final-Touches Phase 6 Stage 6.1 — per-notification mark-as-read button *@
                            <form asp-action="MarkNotificationRead" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@n.Id" />
                                <button type="submit" class="btn btn-sm btn-link p-0 text-muted" title="Mark as read">
                                    <i class="bi bi-check2"></i> Mark read
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    }
}
