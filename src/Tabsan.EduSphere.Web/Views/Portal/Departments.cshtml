@model Tabsan.EduSphere.Web.Models.Portal.DepartmentsPageModel
@{ ViewData["Title"] = "Departments"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-danger">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-3">Departments
                <span class="badge bg-secondary ms-2">@Model.Departments.Count</span>
            </h2>

            @if (Model.Departments.Count == 0)
            {
                <p class="text-muted">No departments found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Code</th>
                                <th>Name</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.Departments)
                            {
                                <tr>
                                    <td><code>@d.Code</code></td>
                                    <td>@d.Name</td>
                                    <td>
                                        <span class="badge @(d.IsActive ? "bg-success" : "bg-secondary")">
                                            @(d.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
