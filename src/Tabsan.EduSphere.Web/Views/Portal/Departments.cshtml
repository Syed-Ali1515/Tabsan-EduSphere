@model Tabsan.EduSphere.Web.Models.Portal.DepartmentsPageModel
@{ ViewData["Title"] = "Departments"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    var alertCls = Model.Message.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @alertCls alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-3">Departments
                <span class="badge bg-secondary ms-2">@Model.Departments.Count</span>
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                {
                    <button type="button" class="btn btn-sm btn-primary float-end" data-bs-toggle="modal" data-bs-target="#createDepartmentModal">
                        <i class="fas fa-plus"></i> Add Department
                    </button>
                }
            </h2>

            @if (Model.Departments.Count == 0)
            {
                <p class="text-muted">No departments found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Code</th>
                                <th>Name</th>
                                <th>Status</th>
                                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                {
                                    <th></th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.Departments)
                            {
                                <tr>
                                    <td><code>@d.Code</code></td>
                                    <td>@d.Name</td>
                                    <td>
                                        <span class="badge @(d.IsActive ? "bg-success" : "bg-secondary")">
                                            @(d.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
                                    {
                                        <td class="text-end">
                                            <button type="button" class="btn btn-xs btn-outline-secondary btn-sm me-1"
                                                    data-bs-toggle="modal" data-bs-target="#editDeptModal"
                                                    data-id="@d.Id" data-name="@d.Name">
                                                Edit
                                            </button>
                                            @if (User.IsInRole("SuperAdmin") && d.IsActive)
                                            {
                                                <form asp-action="DeactivateDepartment" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@d.Id" />
                                                    <button type="submit" class="btn btn-xs btn-outline-danger btn-sm"
                                                            onclick="return confirm('Deactivate @d.Name?')">Deactivate</button>
                                                </form>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@* ── Create Department Modal ───────────────────────────────────────────────── *@
<div class="modal fade" id="createDepartmentModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="CreateDepartment" method="post">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Department</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Department Code <span class="text-danger">*</span></label>
                        <input type="text" name="code" class="form-control" required maxlength="20" placeholder="e.g. CS">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Department Name <span class="text-danger">*</span></label>
                        <input type="text" name="name" class="form-control" required maxlength="200" placeholder="e.g. Computer Science">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </div>
        </form>
    </div>
</div>

@* ── Edit Department Modal ─────────────────────────────────────────────────── *@
<div class="modal fade" id="editDeptModal" tabindex="-1">
    <div class="modal-dialog">
        <form asp-action="UpdateDepartment" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" id="edit_deptId" name="id" />
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Department</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">New Name <span class="text-danger">*</span></label>
                        <input type="text" id="edit_deptName" name="newName" class="form-control" required maxlength="200">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('editDeptModal')?.addEventListener('show.bs.modal', function(e) {
    var btn = e.relatedTarget;
    document.getElementById('edit_deptId').value   = btn.dataset.id;
    document.getElementById('edit_deptName').value = btn.dataset.name;
});
</script>
}
