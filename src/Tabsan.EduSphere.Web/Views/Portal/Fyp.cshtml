@model Tabsan.EduSphere.Web.Models.Portal.FypPageModel
@{ ViewData["Title"] = "FYP Management"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    @if (Model.Departments.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <form method="get" asp-action="Fyp" class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Filter by Department</label>
                        <select name="departmentId" class="form-select" onchange="this.form.submit()">
                            <option value="">All / My Projects</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id" selected="@(Model.SelectedDepartmentId == d.Id ? "selected" : null)">@d.Name</option>
                            }
                        </select>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="row g-3">
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h5 mb-3">Projects
                        <span class="badge bg-secondary ms-1">@Model.Projects.Count</span>
                    </h2>
                    @if (Model.Projects.Count == 0)
                    {
                        <p class="text-muted">No FYP projects found.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr><th>Title</th><th>Student</th><th>Supervisor</th><th>Department</th><th>Status</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in Model.Projects)
                                    {
                                        var badgeCls = p.Status switch
                                        {
                                            "InProgress" or "Approved" => "bg-success",
                                            "Proposed" => "bg-warning text-dark",
                                            "Complete" => "bg-primary",
                                            "Rejected" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                        <tr>
                                            <td>
                                                <div class="fw-semibold">@p.Title</div>
                                                @if (!string.IsNullOrWhiteSpace(p.Description))
                                                {
                                                    <small class="text-muted">@p.Description.Substring(0, Math.Min(80, p.Description.Length))…</small>
                                                }
                                            </td>
                                            <td>@p.StudentName</td>
                                            <td>@(p.SupervisorName ?? "–")</td>
                                            <td>@p.DepartmentName</td>
                                            <td><span class="badge @badgeCls">@p.Status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="h5 mb-3">Upcoming Meetings</h2>
                    @if (Model.UpcomingMeetings.Count == 0)
                    {
                        <p class="text-muted small">No upcoming meetings.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var m in Model.UpcomingMeetings)
                            {
                                <li class="list-group-item px-0">
                                    <div class="fw-semibold small">@m.Title</div>
                                    <div class="text-muted small">@m.ScheduledAt.ToString("dd MMM yyyy, HH:mm")</div>
                                    @if (!string.IsNullOrWhiteSpace(m.Location))
                                    {
                                        <div class="text-muted small">📍 @m.Location</div>
                                    }
                                    <div class="text-muted small">@m.ProjectTitle</div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>
}
