@* Final-Touches Phase 16 Stage 16.2 — Rubric grade view (student/faculty) *@
@model Tabsan.EduSphere.Web.Models.Portal.RubricViewPageModel
@{ ViewData["Title"] = "Rubric Grade"; }

@if (!string.IsNullOrWhiteSpace(Model.Message)) { <div class="alert alert-info">@Model.Message</div> }

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else if (Model.Grade is null)
{
    <div class="alert alert-info">No rubric grade found for this submission.</div>
}
else
{
    var grade = Model.Grade;
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header">
            <h6 class="mb-0">@grade.RubricTitle</h6>
        </div>
        <div class="card-body">
            <p class="mb-3">
                <strong>Total Score:</strong>
                <span class="fs-5 fw-bold text-primary">@grade.TotalPoints / @grade.MaxTotalPoints</span>
            </p>
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Criterion</th>
                            <th>Level Chosen</th>
                            <th>Points</th>
                            <th>Max</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in grade.CriteriaResults)
                        {
                            <tr>
                                <td>@r.CriterionName</td>
                                <td>@(r.ChosenLabel ?? "-")</td>
                                <td>@r.PointsAwarded</td>
                                <td>@r.MaxPoints</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fw-bold">
                            <td colspan="2">Total</td>
                            <td>@grade.TotalPoints</td>
                            <td>@grade.MaxTotalPoints</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
}
