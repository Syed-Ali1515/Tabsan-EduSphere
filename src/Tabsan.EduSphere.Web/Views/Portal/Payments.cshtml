@model Tabsan.EduSphere.Web.Models.Portal.PaymentsPageModel
@{ ViewData["Title"] = "Payment Receipts"; }

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    @if (Model.Departments.Count > 0)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <form method="get" asp-action="Payments" class="row g-2 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label">Filter by Department</label>
                        <select name="departmentId" class="form-select" onchange="this.form.submit()">
                            <option value="">All Departments</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        </select>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h2 class="h5 mb-3">Receipts <span class="badge bg-secondary ms-1">@Model.Payments.Count</span></h2>

            @if (Model.Payments.Count == 0)
            {
                <p class="text-muted">No payment receipts found.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Student</th>
                                <th>Fee Type</th>
                                <th>Amount</th>
                                <th>Due Date</th>
                                <th>Paid At</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Payments)
                            {
                                var badgeCls = r.Status switch
                                {
                                    "Paid" => "bg-success",
                                    "Pending" => "bg-warning text-dark",
                                    "Overdue" => "bg-danger",
                                    _ => "bg-secondary"
                                };
                                <tr>
                                    <td>@r.StudentName</td>
                                    <td>@r.FeeType</td>
                                    <td class="fw-semibold">@r.Amount.ToString("N2")</td>
                                    <td>@r.DueDate.ToString("dd MMM yyyy")</td>
                                    <td>@(r.PaidDate?.ToString("dd MMM yyyy") ?? "–")</td>
                                    <td><span class="badge @badgeCls">@r.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}
