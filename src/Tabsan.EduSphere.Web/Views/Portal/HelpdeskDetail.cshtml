@model Tabsan.EduSphere.Web.Models.Portal.HelpdeskDetailPageModel
@using Tabsan.EduSphere.Web.Models.Portal
@{
    ViewData["Title"] = "Ticket Detail";
    var ticket = Model.Ticket;
    var isStaff = Model.CallerRole is "SuperAdmin" or "Admin";
    var isFaculty = Model.CallerRole == "Faculty";
    var canInternalNotes = isStaff || isFaculty;
}

@if (TempData["Message"] is string msg)
{
    var cls = msg.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @cls alert-dismissible fade show" role="alert">
        @msg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else if (ticket is null)
{
    <div class="alert alert-danger">Ticket not found or you do not have access.</div>
    <a asp-action="Helpdesk" class="btn btn-outline-secondary">Back to Tickets</a>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h5 mb-1">@ticket.Subject</h2>
            <div class="d-flex gap-2 align-items-center flex-wrap">
                <span class="badge bg-secondary">@ticket.Category</span>
                <partial name="_TicketStatusBadge" model="ticket.Status" />
                <span class="text-muted small">Created @ticket.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
            </div>
        </div>
        <a asp-action="Helpdesk" class="btn btn-sm btn-outline-secondary">Back to Tickets</a>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <p class="mb-2">@ticket.Body</p>
            <div class="small text-muted">
                Submitted by <strong>@ticket.SubmitterName</strong>
                @if (!string.IsNullOrWhiteSpace(ticket.AssigneeName))
                {
                    <span> • Assigned to <strong>@ticket.AssigneeName</strong></span>
                }
            </div>
        </div>
    </div>

    @if (isStaff)
    {
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h3 class="h6 mb-3">Assignment</h3>
                <form asp-action="HelpdeskAssign" method="post" class="row g-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ticketId" value="@ticket.Id" />
                    <div class="col-md-8">
                        <label class="form-label">Assign to Faculty</label>
                        <select name="assignedToId" class="form-select" required>
                            <option value="">Select faculty</option>
                            @foreach (var u in Model.StaffUsers)
                            {
                                <option value="@u.Id" selected="@(ticket.AssignedToId == u.Id)">@u.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="submit" class="btn btn-outline-primary w-100">Assign</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <h3 class="h6 mb-3">Conversation</h3>

            @{
                var visibleMessages = canInternalNotes
                    ? ticket.Messages
                    : ticket.Messages.Where(m => !m.IsInternalNote).ToList();
            }

            @if (!visibleMessages.Any())
            {
                <div class="alert alert-light border">No replies yet.</div>
            }
            else
            {
                <div class="d-flex flex-column gap-2">
                    @foreach (var m in visibleMessages.OrderBy(x => x.CreatedAt))
                    {
                        <div class="border rounded p-2 @(m.IsInternalNote ? "bg-light" : "")">
                            <div class="d-flex justify-content-between">
                                <strong>@m.AuthorName</strong>
                                <span class="text-muted small">@m.CreatedAt.ToString("dd MMM yyyy HH:mm")</span>
                            </div>
                            @if (m.IsInternalNote)
                            {
                                <div><span class="badge bg-dark">Internal Note</span></div>
                            }
                            <div class="mt-1">@m.Body</div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
            <h3 class="h6 mb-3">Post Reply</h3>
            <form asp-action="HelpdeskAddMessage" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ticketId" value="@ticket.Id" />
                <div class="mb-2">
                    <textarea name="body" class="form-control" rows="4" maxlength="5000" required placeholder="Write your response..."></textarea>
                </div>
                @if (canInternalNotes)
                {
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="isInternalNote" name="isInternalNote" value="true" />
                        <label class="form-check-label" for="isInternalNote">Internal note (staff only)</label>
                    </div>
                }
                <button type="submit" class="btn btn-primary">Post Reply</button>
            </form>
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        @if (isStaff || isFaculty)
        {
            <form asp-action="HelpdeskResolve" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ticketId" value="@ticket.Id" />
                <button type="submit" class="btn btn-success">Resolve</button>
            </form>
        }

        @if (isStaff)
        {
            <form asp-action="HelpdeskClose" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ticketId" value="@ticket.Id" />
                <button type="submit" class="btn btn-outline-secondary">Close</button>
            </form>
        }

        @if (ticket.CanReopen && ticket.SubmitterId == Model.CallerId)
        {
            <form asp-action="HelpdeskReopen" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ticketId" value="@ticket.Id" />
                <button type="submit" class="btn btn-warning">Reopen</button>
            </form>
        }
    </div>
}
