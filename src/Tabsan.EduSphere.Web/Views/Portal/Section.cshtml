@{
    var title = ViewData["Title"]?.ToString() ?? "Portal Section";
    var description = ViewData["SectionDescription"]?.ToString() ?? "Section under construction.";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <h2 class="h4 mb-3">@title</h2>
        <p class="text-muted mb-4">@description</p>

        <div class="alert alert-info" role="alert">
            This page is scaffolded and ready for feature implementation in the next step.
        </div>
    </div>
</div>
