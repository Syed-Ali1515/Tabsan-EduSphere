@model Tabsan.EduSphere.Web.Models.Portal.ThemeSettingsPageModel
@{
    ViewData["Title"] = "Theme Settings";
    var tempMsg = TempData["Message"] as string ?? Model.Message;
}

<div class="row g-4">

    @if (!Model.IsConnected)
    {
        <div class="col-12">
            <div class="alert alert-warning d-flex align-items-center gap-2">
                <i class="bi bi-plug-fill"></i>
                Not connected to the API. Configure the connection on the Dashboard.
            </div>
        </div>
    }

    @* Final-Touches Phase 5 Stage 5.1 — contextual success/danger alert feedback *@
    @if (!string.IsNullOrWhiteSpace(tempMsg))
    {
        var alertClass = tempMsg!.StartsWith("Error") ? "alert-danger" : "alert-success";
        var alertIcon  = tempMsg.StartsWith("Error") ? "bi-x-circle-fill" : "bi-check-circle-fill";
        <div class="col-12">
            <div class="alert @alertClass alert-dismissible fade show" role="alert">
                <i class="bi @alertIcon me-2"></i>@tempMsg
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-palette-fill text-primary"></i>
                <strong>Portal Colour Theme</strong>
                <span class="ms-auto text-muted small">Click a theme to preview, then save.</span>
            </div>
            <div class="card-body">
                <div id="themeGrid" class="d-flex flex-wrap gap-3 mb-4">
                    @foreach (var theme in Model.Themes)
                    {
                        var isActive = (Model.CurrentTheme ?? "") == theme.Key;
                        <button type="button"
                                class="theme-swatch btn @(isActive ? "border-primary border-2" : "border")"
                                data-theme-key="@theme.Key"
                                title="@theme.DisplayName"
                                style="width:90px;height:70px;background:@theme.PreviewColor;color:#fff;font-size:0.7rem;border-radius:8px;position:relative;"
                                onclick="previewTheme('@theme.Key')">
                            @if (isActive)
                            {
                                <i class="bi bi-check-circle-fill" style="position:absolute;top:4px;right:6px;font-size:1rem;"></i>
                            }
                            <span style="position:absolute;bottom:6px;left:0;right:0;text-align:center;text-shadow:0 1px 2px rgba(0,0,0,.7);">
                                @theme.DisplayName
                            </span>
                        </button>
                    }
                </div>

                <form asp-action="SetTheme" method="post" id="themeForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="themeKey" id="themeKeyInput" value="@(Model.CurrentTheme ?? "")" />
                    <button type="submit" class="btn btn-primary" @(Model.IsConnected ? "" : "disabled")>
                        <i class="bi bi-floppy me-1"></i> Save Theme
                    </button>
                    <button type="button" class="btn btn-outline-secondary ms-2" onclick="previewTheme('')">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Reset Preview
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function previewTheme(key) {
        document.documentElement.setAttribute('data-theme', key);
        document.getElementById('themeKeyInput').value = key;
        // highlight selected swatch
        document.querySelectorAll('.theme-swatch').forEach(btn => {
            const isSelected = btn.dataset.themeKey === key;
            btn.classList.toggle('border-primary', isSelected);
            btn.classList.toggle('border-2', isSelected);
        });
    }

    // Apply current theme on load for preview consistency
    (function () {
        const saved = '@Html.Raw(Model.CurrentTheme ?? "")';
        if (saved) document.documentElement.setAttribute('data-theme', saved);
    })();
</script>
}
