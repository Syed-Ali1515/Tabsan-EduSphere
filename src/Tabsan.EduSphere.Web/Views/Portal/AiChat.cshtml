@model Tabsan.EduSphere.Web.Models.Portal.AiChatPageModel
@{ ViewData["Title"] = "AI Chat"; }

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="row g-0 border rounded shadow-sm" style="height:72vh;min-height:400px;">
        <!-- Sidebar -->
        <div class="col-3 border-end d-flex flex-column" style="overflow:hidden;">
            <div class="p-2 border-bottom bg-light">
                <span class="fw-semibold small">Conversations</span>
            </div>
            <div class="flex-grow-1 overflow-auto">
                @if (Model.Conversations.Count == 0)
                {
                    <p class="text-muted small p-2">No conversations yet.</p>
                }
                else
                {
                    <div class="list-group list-group-flush">
                        @foreach (var c in Model.Conversations)
                        {
                            var isActive = Model.ActiveConversationId == c.Id;
                            <a asp-action="AiChat" asp-route-conversationId="@c.Id"
                               class="list-group-item list-group-item-action py-2 px-3 @(isActive ? "active" : "")">
                                <div class="small fw-semibold text-truncate">@c.Title</div>
                                <div class="text-muted" style="font-size:0.72rem;">
                                    @(c.LastMessageAt?.ToString("dd MMM, HH:mm") ?? c.CreatedAt.ToString("dd MMM, HH:mm"))
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
            <div class="p-2 border-top">
                <a asp-action="AiChat" class="btn btn-outline-primary btn-sm w-100">+ New Chat</a>
            </div>
        </div>

        <!-- Chat area -->
        <div class="col-9 d-flex flex-column">
            <div id="messageArea" class="flex-grow-1 p-3 overflow-auto">
                @if (Model.CurrentMessages.Count == 0)
                {
                    <div class="text-center text-muted mt-5">
                        <div class="fs-1">🤖</div>
                        <p>Ask me anything about your studies!</p>
                    </div>
                }
                else
                {
                    @foreach (var m in Model.CurrentMessages)
                    {
                        var isUser = m.Role == "user";
                        <div class="d-flex @(isUser ? "justify-content-end" : "justify-content-start") mb-2">
                            <div class="rounded-3 px-3 py-2 @(isUser ? "bg-primary text-white" : "bg-light border")"
                                 style="max-width:80%;">
                                <div>@m.Content</div>
                                <div class="@(isUser ? "text-white-50" : "text-muted")" style="font-size:0.7rem;">
                                    @m.CreatedAt.ToString("HH:mm")
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Message))
            {
                <div class="alert alert-danger mx-3 mb-2 py-2">@Model.Message</div>
            }

            <div class="border-top p-2">
                <form asp-action="AiChatSend" method="post" class="d-flex gap-2">
                    <input type="hidden" name="conversationId" value="@Model.ActiveConversationId" />
                    <input type="text" name="message" class="form-control"
                           placeholder="Type your message…" autocomplete="off" required />
                    <button type="submit" class="btn btn-primary">Send</button>
                </form>
            </div>
        </div>
    </div>
}

<script>
    (function () {
        var el = document.getElementById('messageArea');
        if (el) el.scrollTop = el.scrollHeight;
    })();
</script>
