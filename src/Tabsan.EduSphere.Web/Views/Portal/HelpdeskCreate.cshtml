@model Tabsan.EduSphere.Web.Models.Portal.HelpdeskCreatePageModel
@using Tabsan.EduSphere.Web.Models.Portal
@{
    ViewData["Title"] = "New Support Ticket";
}

@if (TempData["Message"] is string msg)
{
    var cls = msg.StartsWith("Error") ? "alert-danger" : "alert-success";
    <div class="alert @cls alert-dismissible fade show" role="alert">
        @msg <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.IsConnected)
{
    <div class="alert alert-warning">Not connected. <a asp-action="Dashboard">Configure API</a>.</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Create Support Ticket</h2>
        <a asp-action="Helpdesk" class="btn btn-sm btn-outline-secondary">Back to Tickets</a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="HelpdeskCreate" method="post">
                @Html.AntiForgeryToken()

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Department (optional)</label>
                        <select name="departmentId" class="form-select">
                            <option value="">General / Not specific</option>
                            @foreach (var d in Model.Departments)
                            {
                                <option value="@d.Id">@d.Name</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Category</label>
                        <select name="category" class="form-select" required>
                            @foreach (var c in Enum.GetValues<TicketCategoryWeb>())
                            {
                                <option value="@((int)c)" selected="@(c == Model.Category)">@c</option>
                            }
                        </select>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Subject</label>
                        <input name="subject" class="form-control" maxlength="200" required placeholder="Short summary of your issue" />
                    </div>

                    <div class="col-12">
                        <label class="form-label">Details</label>
                        <textarea name="body" class="form-control" rows="7" maxlength="5000" required placeholder="Please include context, steps, and expected outcome."></textarea>
                    </div>
                </div>

                <div class="mt-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Submit Ticket</button>
                    <a asp-action="Helpdesk" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
}
