{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "yourdomain.com;www.yourdomain.com",
  "EduApi": {
    "BaseUrl": "https://yourdomain.com"
  },
  "AppSettings": {
    "AppName": "Tabsan EduSphere Web",
    "AppVersion": "1.0.0",
    "WebBaseUrl": "https://yourdomain.com"
  },
  "ScaleOut": {
    "SharedDataProtectionKeyRingPath": "REPLACE_WITH_SHARED_NETWORK_PATH_OR_MOUNT"
  },
  "StaticAssetCaching": {
    "Enabled": true,
    "MaxAgeSeconds": 86400
  },
  "ReverseProxy": {
    "Enabled": true,
    "RequireHeaderSymmetry": true,
    "ForwardLimit": 2,
    "KnownProxies": [ "127.0.0.1" ]
  }
}
