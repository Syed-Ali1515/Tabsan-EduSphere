{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "yourdomain.com;www.yourdomain.com",
  "ConnectionStrings": {
    "DefaultConnection": "REPLACE_WITH_PRODUCTION_CONNECTION_STRING_OR_SET_VIA_ENV_VAR"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_PRODUCTION_SECRET_KEY_MIN_32_CHARS_OR_SET_VIA_ENV_VAR",
    "Issuer": "https://yourdomain.com",
    "Audience": "tabsan-edusphere-clients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "AuthSecurity": {
    "Mfa": {
      "Enabled": false,
      "RequireForPasswordLogin": false,
      "DemoCode": "REPLACE_OR_SET_VIA_ENV_VAR"
    },
    "Sso": {
      "Enabled": false,
      "Provider": "",
      "LoginUrl": ""
    },
    "SessionRisk": {
      "Enabled": true,
      "BlockHighRiskLogin": true,
      "AuditMediumRiskLogin": true
    }
  },
  "License": {
    "PublicKeyPem": ""
  },
  "Email": {
    "SmtpHost": "smtp.yourdomain.com",
    "SmtpPort": 587,
    "Username": "REPLACE_WITH_SMTP_USERNAME_OR_SET_VIA_ENV_VAR",
    "Password": "REPLACE_WITH_SMTP_PASSWORD_OR_SET_VIA_ENV_VAR",
    "FromAddress": "noreply@yourdomain.com",
    "FromName": "Tabsan EduSphere",
    "EnableSsl": true
  },
  "AppSettings": {
    "EnableSwagger": false,
    "EnableDetailedErrors": false,
    "CorsOrigins": [ "https://yourdomain.com", "https://www.yourdomain.com" ]
  },
  "ScaleOut": {
    "RedisConnectionString": "REPLACE_WITH_REDIS_CONNECTION_STRING_OR_SET_VIA_ENV_VAR",
    "RedisInstanceName": "Tabsan.EduSphere:"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    }
  }
}
