{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "yourdomain.com;www.yourdomain.com",
  "ConnectionStrings": {
    "DefaultConnection": "REPLACE_WITH_PRODUCTION_CONNECTION_STRING_OR_SET_VIA_ENV_VAR;Min Pool Size=50;Max Pool Size=800;Connect Timeout=30"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_PRODUCTION_SECRET_KEY_MIN_32_CHARS_OR_SET_VIA_ENV_VAR",
    "Issuer": "https://yourdomain.com",
    "Audience": "tabsan-edusphere-clients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "AuthSecurity": {
    "Mfa": {
      "Enabled": false,
      "RequireForPasswordLogin": false,
      "DemoCode": "REPLACE_OR_SET_VIA_ENV_VAR"
    },
    "Sso": {
      "Enabled": false,
      "Provider": "",
      "LoginUrl": ""
    },
    "SessionRisk": {
      "Enabled": true,
      "BlockHighRiskLogin": true,
      "AuditMediumRiskLogin": true
    }
  },
  "License": {
    "PublicKeyPem": ""
  },
  "Email": {
    "SmtpHost": "smtp.yourdomain.com",
    "SmtpPort": 587,
    "Username": "REPLACE_WITH_SMTP_USERNAME_OR_SET_VIA_ENV_VAR",
    "Password": "REPLACE_WITH_SMTP_PASSWORD_OR_SET_VIA_ENV_VAR",
    "FromAddress": "noreply@yourdomain.com",
    "FromName": "Tabsan EduSphere",
    "EnableSsl": true
  },
  "AppSettings": {
    "ApiBaseUrl": "https://yourdomain.com/api",
    "WebBaseUrl": "https://yourdomain.com",
    "EnableSwagger": false,
    "EnableDetailedErrors": false,
    "CorsOrigins": [ "https://yourdomain.com", "https://www.yourdomain.com" ]
  },
  "ScaleOut": {
    "InstanceId": "REPLACE_WITH_NODE_ID_OR_SET_VIA_ENV_VAR",
    "ExposeInstanceHeader": true,
    "RedisConnectionString": "REPLACE_WITH_REDIS_CONNECTION_STRING_OR_SET_VIA_ENV_VAR",
    "RedisInstanceName": "Tabsan.EduSphere:"
  },
  "ReverseProxy": {
    "Enabled": true,
    "RequireHeaderSymmetry": true,
    "ForwardLimit": 2,
    "KnownProxies": [ "127.0.0.1" ]
  },
  "IntegrationGateway": {
    "Enabled": true,
    "MaxDeadLetters": 500,
    "Channels": {
      "payment": {
        "MaxRetries": 3,
        "TimeoutSeconds": 20,
        "BaseDelayMilliseconds": 300,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "email": {
        "MaxRetries": 3,
        "TimeoutSeconds": 20,
        "BaseDelayMilliseconds": 250,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "sms": {
        "MaxRetries": 3,
        "TimeoutSeconds": 15,
        "BaseDelayMilliseconds": 200,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "push": {
        "MaxRetries": 2,
        "TimeoutSeconds": 10,
        "BaseDelayMilliseconds": 150,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "lms-external-api": {
        "MaxRetries": 3,
        "TimeoutSeconds": 15,
        "BaseDelayMilliseconds": 200,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 4,
        "CircuitBreakerOpenSeconds": 45
      }
    }
  },
  "MediaStorage": {
    "Provider": "Local",
    "LocalRootPath": "uploads",
    "BlobRootPath": "blob-storage",
    "PublicBaseUrl": "",
    "KeyPrefix": "prod",
    "SignedUrlSecret": "REPLACE_WITH_MEDIA_SIGNING_SECRET_OR_SET_VIA_ENV_VAR"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      }
    }
  }
}
