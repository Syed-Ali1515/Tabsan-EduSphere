{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TabsanEduSphere;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True;Min Pool Size=20;Max Pool Size=500;Connect Timeout=30"
  },
  "AppSettings": {
    "ApiBaseUrl": "https://localhost:5181",
    "WebBaseUrl": "https://localhost:5063",
    "EnableSwagger": true,
    "EnableDetailedErrors": true,
    "CorsOrigins": [ "https://localhost:5063", "http://localhost:5063" ]
  },
  "QueuePlatform": {
    "Provider": "InMemory",
    "RabbitMq": {
      "Enabled": false,
      "ConnectionString": "",
      "AccountSecurityEmailQueueName": "tabsan.account-security.email",
      "PollDelayMilliseconds": 300
    }
  },
  "IntegrationGateway": {
    "Enabled": true,
    "MaxDeadLetters": 300,
    "Channels": {
      "payment": {
        "MaxRetries": 2,
        "TimeoutSeconds": 20,
        "BaseDelayMilliseconds": 300,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "email": {
        "MaxRetries": 2,
        "TimeoutSeconds": 20,
        "BaseDelayMilliseconds": 250,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "sms": {
        "MaxRetries": 2,
        "TimeoutSeconds": 15,
        "BaseDelayMilliseconds": 200,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "push": {
        "MaxRetries": 1,
        "TimeoutSeconds": 10,
        "BaseDelayMilliseconds": 150,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 5,
        "CircuitBreakerOpenSeconds": 30
      },
      "lms-external-api": {
        "MaxRetries": 2,
        "TimeoutSeconds": 15,
        "BaseDelayMilliseconds": 200,
        "ExponentialBackoffEnabled": true,
        "CircuitBreakerFailureThreshold": 4,
        "CircuitBreakerOpenSeconds": 45
      }
    }
  },
  "MediaStorage": {
    "Provider": "Local",
    "LocalRootPath": "uploads",
    "BlobRootPath": "blob-storage",
    "PublicBaseUrl": "",
    "KeyPrefix": "dev",
    "SignedUrlSecret": "dev-media-signing-secret"
  }
}
