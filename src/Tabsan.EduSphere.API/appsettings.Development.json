{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=TabsanEduSphere;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "AppSettings": {
    "EnableSwagger": true,
    "EnableDetailedErrors": true,
    "CorsOrigins": [ "https://localhost:5063", "http://localhost:5063" ]
  },
  "MediaStorage": {
    "Provider": "Local",
    "LocalRootPath": "uploads",
    "BlobRootPath": "blob-storage",
    "PublicBaseUrl": "",
    "KeyPrefix": "dev"
  }
}
