{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=TabsanEduSphere;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_TO_A_LONG_RANDOM_KEY_IN_PRODUCTION_MIN_32_CHARS",
    "Issuer": "https://localhost:7001",
    "Audience": "tabsan-edusphere-clients",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "AuthSecurity": {
    "Mfa": {
      "Enabled": false,
      "RequireForPasswordLogin": false,
      "DemoCode": "000000"
    },
    "Sso": {
      "Enabled": false,
      "Provider": "",
      "LoginUrl": ""
    },
    "SessionRisk": {
      "Enabled": true,
      "BlockHighRiskLogin": true,
      "AuditMediumRiskLogin": true
    }
  },
  "License": {
    "PublicKeyPem": ""
  },
  "Email": {
    "SmtpHost": "smtp.example.com",
    "SmtpPort": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@tabsan-edusphere.com",
    "FromName": "Tabsan EduSphere",
    "EnableSsl": true
  },
  "AppSettings": {
    "AppName": "Tabsan EduSphere",
    "AppVersion": "1.0.0",
    "ApiBaseUrl": "",
    "WebBaseUrl": "",
    "EnableSwagger": false,
    "EnableDetailedErrors": false,
    "CorsOrigins": []
  },
  "ScaleOut": {
    "RedisConnectionString": "",
    "RedisInstanceName": "Tabsan.EduSphere:"
  },
  "ReverseProxy": {
    "Enabled": false,
    "RequireHeaderSymmetry": true,
    "ForwardLimit": 2,
    "KnownProxies": []
  },
  "IntegrationGateway": {
    "Enabled": true,
    "MaxDeadLetters": 200,
    "Channels": {
      "payment": {
        "MaxRetries": 2,
        "TimeoutSeconds": 20,
        "BaseDelayMilliseconds": 300,
        "ExponentialBackoffEnabled": true
      },
      "email": {
        "MaxRetries": 2,
        "TimeoutSeconds": 20,
        "BaseDelayMilliseconds": 250,
        "ExponentialBackoffEnabled": true
      },
      "sms": {
        "MaxRetries": 2,
        "TimeoutSeconds": 15,
        "BaseDelayMilliseconds": 200,
        "ExponentialBackoffEnabled": true
      },
      "push": {
        "MaxRetries": 1,
        "TimeoutSeconds": 10,
        "BaseDelayMilliseconds": 150,
        "ExponentialBackoffEnabled": true
      },
      "lms-external-api": {
        "MaxRetries": 2,
        "TimeoutSeconds": 15,
        "BaseDelayMilliseconds": 200,
        "ExponentialBackoffEnabled": true
      }
    }
  },
  "MediaStorage": {
    "Provider": "Local",
    "LocalRootPath": "uploads",
    "BlobRootPath": "blob-storage",
    "PublicBaseUrl": "",
    "KeyPrefix": "",
    "SignedUrlSecret": ""
  }
}
